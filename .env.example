# OpenAI credentials for the RAG answer-generation (Module 1).
# Copy this file to .env and fill in your key. .env is gitignored.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Local alternative: Ollama ---
# The `openai` SDK will talk to any OpenAI-compatible endpoint, including Ollama's
# (https://github.com/ollama/ollama/blob/main/docs/openai.md). To use a local model
# instead of the OpenAI API, comment out the two lines above and uncomment these
# (api key can be any non-empty string — Ollama doesn't check it):
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen3:30b
